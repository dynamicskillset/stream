{
  "manifest_version": 3,
  "name": "Stream",
  "version": "0.1.0",
  "description": "Velocity-based RSS reader. Articles arrive, linger, and fade.",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "32":  "icons/icon.svg",
    "128": "icons/icon.svg"
  },
  "action": {
    "default_title": "Open Stream",
    "default_icon":  "icons/icon.svg"
  },
  "permissions": [
    "storage"
  ],
  "optional_permissions": [
    "<all_urls>"
  ],
  "host_permissions": []
}
